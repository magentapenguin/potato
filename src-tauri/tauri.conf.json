{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Potato Game",
  "version": "0.1.3",
  "identifier": "dev.magentapenugin.potato",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "npm run dev"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0RDVDQjM1NURCOEU2NUMKUldSYzVyaGROY3ZWZEpGbExsSUtmZWJ4WWc1NUZkTWQ0K1Z2eHZyQzZMMVR5bC91SXN1elQyT0kK",
      "endpoints": [
        "https://github.com/magentapenguin/potato/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "2.5d Maze Game",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "fileAssociations": [
       {
        "ext": [".potato", ".cfg.potato"],
        "name": "Potato Save File",
        "role": "Editor",
        "description": "Potato Game Save File",
        "mimeType": "application/x-potato"
       }
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
