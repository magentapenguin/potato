{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Potato Game",
  "version": "0.1.1",
  "identifier": "dev.magentapenugin.potato",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8000",
    "beforeDevCommand": "python -m http.server"
  },
  "app": {
    "windows": [
      {
        "title": "2.5d Maze Game",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
